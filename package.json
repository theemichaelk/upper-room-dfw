{
  "name": "upper-room-dfw-local-directory",
  "version": "2.0.0",
  "description": "DFW Church Directory platform with production API, Stripe billing, and member portal",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node server/index.js",
    "restart": "node scripts/restart-server.js",
    "dev:static": "npx serve . -l 8000 --cors",
    "test:all": "node scripts/test-api.js && node scripts/test-features.js",
    "generate:church": "node scripts/generate-church.js",
    "generate:missing": "node scripts/generate-missing-pages.js",
    "generate:templates": "node scripts/generate-templates.js",
    "generate:sitemap": "node scripts/generate-sitemap.js",
    "expand:churches": "node scripts/expand-churches-bulk.js",
    "setup:stripe": "node scripts/setup-stripe.js",
    "setup:amplify-iam": "node scripts/setup-amplify-iam.js",
    "push:env": "node scripts/push-env-to-amplify.js",
    "push:live": "node scripts/push-live.js",
    "test:production": "node scripts/test-production.js",
    "expand:all": "node scripts/expand-churches-bulk.js && node scripts/generate-sitemap.js",
    "inject:platform": "node scripts/inject-platform.js",
    "sync:site-settings": "node scripts/sync-site-settings.js",
    "audit:injection": "node scripts/audit-injection.js",
    "audit:duplicates": "node scripts/audit-duplicates.js",
    "audit:sanitize": "node scripts/sanitize-audit.js",
    "redirects:apply": "node scripts/apply-redirects.js --refresh --canonicals",
    "rebuild:site": "node scripts/rebuild-site.js",
    "test:features": "node scripts/test-features.js",
    "test:api": "node scripts/test-api.js",
    "test:dns": "node scripts/test-dns.js",
    "test:smtp": "node scripts/test-smtp.js",
    "verify:integrations": "node scripts/verify-integrations.js",
    "seo:meta": "node scripts/add-seo-meta.js && node scripts/export-page-metadata.js",
    "footer:inject": "node scripts/add-powered-by-footer.js",
    "build": "node scripts/inject-platform.js && node scripts/add-powered-by-footer.js && node scripts/build-amplify-bundle.js",
    "generate:blog": "node scripts/generate-blog.js",
    "build:static": "node scripts/generate-blog.js && node scripts/apply-brand-logo.js && node scripts/inject-platform.js && node scripts/add-powered-by-footer.js && node scripts/apply-redirects.js --canonicals && node scripts/generate-sitemap.js",
    "brand:logo": "node scripts/apply-brand-logo.js",
    "deploy:s3": "npm run build:static && aws s3 sync . s3://upperroomdfw.com --region us-east-2 --delete --exclude node_modules/* --exclude .amplify-hosting/* --exclude .env --exclude .env.example --exclude server/* --exclude scripts/* --exclude deploy/* --exclude .git/* --exclude .vscode/* --exclude 18-portal.js --exclude build-amplify-bundle.js --exclude ensure-admins.js --exclude main.css --exclude main.js --exclude *.db --exclude *.db-shm --exclude *.db-wal"
  },
  "keywords": [
    "dfw",
    "church",
    "directory",
    "saas",
    "stripe"
  ],
  "author": "Grok Build",
  "dependencies": {
    "@aws-sdk/client-route-53": "^3.1075.0",
    "@aws-sdk/client-s3": "^3.1073.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.16",
    "stripe": "^17.5.0"
  }
}
