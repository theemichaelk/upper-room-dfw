# Upper Room DFW — Production environment
PORT=8000
APP_URL=http://localhost:8000
NODE_ENV=production

# Required in production — generate: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Admin login (admin.html) — comma-separated admin emails
ADMIN_EMAILS=admin@upperroomdfw.com
ADMIN_EMAIL=admin@upperroomdfw.com
ADMIN_PASSWORD=change-me-strong-password

# Stripe — test|live (defaults: test in dev, live in production)
STRIPE_MODE=live
STRIPE_PUBLISHABLE_KEY_TEST=pk_test_...
STRIPE_SECRET_KEY_TEST=sk_test_...
STRIPE_PUBLISHABLE_KEY_LIVE=pk_live_...
STRIPE_SECRET_KEY_LIVE=sk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STANDARD=price_...
STRIPE_PRICE_PREMIUM=price_...

# Vbout
VBOUT_API_KEY=
VBOUT_LIST_ID=

# Mailchimp (server prefix is suffix after dash in API key, e.g. us3)
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=us3
MAILCHIMP_LIST_ID=

# TinyURL (api.tinyurl.com)
TINYURL_API_TOKEN=

# Route53 DNS
ROUTE53_HOSTED_ZONE_ID=
CLOUDFRONT_DOMAIN=
AMPLIFY_DOMAIN=

# PayPal REST
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=live

# PayPal Express Checkout (NVP)
PAYPAL_API_USERNAME=
PAYPAL_API_PASSWORD=
PAYPAL_API_SIGNATURE=
PAYPAL_IPN_URL=

# SMTP (Acumbamail relay or AWS SES)
SMTP_PROVIDER=acumbamail
SMTP_HOST=smtp.acumbamail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
EMAIL_FROM=Upper Room DFW <noreply@yourdomain.com>
ACUMBAMAIL_API_KEY=
ACUMBAMAIL_LIST_ID=

# Database (optional — defaults to server/data/urdfw.db)
# DATABASE_PATH=/var/data/urdfw.db