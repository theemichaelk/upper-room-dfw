{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "UrdfwDbBackupReadWrite",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:HeadObject", "s3:DeleteObject"],
      "Resource": [
        "arn:aws:s3:::upperroomdfw.com/data/*",
        "arn:aws:s3:::upperroomdfw.com/media/*"
      ]
    },
    {
      "Sid": "UrdfwDbBackupList",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::upperroomdfw.com",
      "Condition": {
        "StringLike": { "s3:prefix": ["data/*", "media/*"] }
      }
    }
  ]
}